<Page x:Class="AsynAwaitExamples.Steps.Step04_SequentialCalls"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:AsynAwaitExamples.ViewModels"
      Title="Step 4 - Sequential Calls">
    <Page.DataContext>
        <vm:Step04ViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Style="{StaticResource HeaderStyle}" 
                       Text="Step 4: Sequential Async Calls"/>

            <TextBlock Style="{StaticResource ExplanationStyle}">
                ? SEQUENTIAL: Running async operations ONE AFTER ANOTHER.
                
                When you "await" multiple operations in order, each one waits for the previous
                one to finish before starting. This is called "sequential" execution.
                
                This is useful when the second task DEPENDS on the result of the first.
                For example: first get the user ID, then use that ID to get their orders.
                
                Total time = sum of all individual times.
                If task A takes 2s and task B takes 2s ? total is 4 seconds.
            </TextBlock>

            <Button Style="{StaticResource ActionButton}"
                    Content="? Run 3 tasks SEQUENTIALLY (one after another)"
                    Command="{Binding RunSequentialCommand}"/>

            <TextBox Style="{StaticResource OutputStyle}" Height="300"
                     Text="{Binding OutputText, Mode=OneWay}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
